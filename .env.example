# ---- Yarn Procurement Portal config ----
# Copy this file to ".env" (in project root) and adjust.

# Port the server listens on
PORT=4043

# Public base URL used to build vendor self-service quote links.
# On your laptop keep localhost. On the VM, set to the server's real URL,
# e.g. https://procurement.ddecor.com
PUBLIC_BASE_URL=http://localhost:4043

# Secret used to sign login sessions (CHANGE THIS in production)
JWT_SECRET=change-me-to-a-long-random-string

# Currency / locale defaults
DEFAULT_CURRENCY=INR

# ---- Super Admin (top-level account, ensured on every server start) ----
# Set these in production so a secure admin always exists (independent of the
# demo seed). Leave blank to skip. Use a strong, unique password.
SUPER_ADMIN_EMAIL=admin@ddecor.com
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin
# Set to 'true' for ONE boot to force-reset the super admin's password, then
# remove it / set back to false.
SUPER_ADMIN_RESET_PASSWORD=false

# ---- PostgreSQL ----
# Either set DATABASE_URL (takes precedence) ...
# DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/yarn_procurement
# ... or the individual parts:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=yarn_procurement
PGSSL=false

# ---- Email mode ----
# draft  = generate RFQ email text + .eml file + mailto (no credentials needed) [default]
# smtp   = actually send via SMTP (fill the SMTP_* values below)
MAIL_MODE=draft
MAIL_FROM="Yarn Procurement <procurement@ddecor.com>"

# Office 365 example (used only when MAIL_MODE=smtp)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
