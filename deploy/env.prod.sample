# ---- Yarn Procurement Portal — PRODUCTION .env (honocode) ----
# Copy to /data/yp/.env on the server and fill the secrets. Do NOT commit.

PORT=4043
PUBLIC_BASE_URL=https://yp.ddecor.com        # vendor quote links resolve from here
JWT_SECRET=                                   # REQUIRED: openssl rand -base64 48
DEFAULT_CURRENCY=INR

# ---- Shared Postgres (postgres_common, reachable over the shared_proxy net) ----
PGHOST=postgres_common
PGPORT=5432
PGUSER=yarn_app
PGPASSWORD=                                    # REQUIRED: the yarn_app role password you create
PGDATABASE=yarn_procurement
PGSSL=false

# ---- Super Admin (ensured on every boot) ----
SUPER_ADMIN_EMAIL=superadmin@ddecor.com
SUPER_ADMIN_PASSWORD=                          # REQUIRED: strong, unique
SUPER_ADMIN_NAME=Super Admin
# Set true for the FIRST boot (the restored snapshot already has this account
# with the laptop password), then set back to false and redeploy.
SUPER_ADMIN_RESET_PASSWORD=false

# ---- Email ----
MAIL_MODE=draft                                # or 'smtp' + the SMTP_* values
MAIL_FROM="Yarn Procurement <procurement@ddecor.com>"
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
